{
  "name": "quillbytes/payroll-engine",
  "description": "Reusable Laravel payroll engine for scalable, auditable, and customizable payroll computation.",
  "keywords": [
    "payroll",
    "payroll-engine",
    "payroll-engine-laravel",
    "payroll-engine-php",
    "moneyphp",
    "quillbytes"
  ],
  "homepage": "https://github.com/quillbytes/payroll-engine",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Jovanie Daclizon",
      "email": "jovanie.daclizon@gmail.com",
      "role": "Developer"
    }
  ],
  "version": "1.2.1",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0|^13.0",
    "moneyphp/money": "^4.8"
  },
  "require-dev": {
    "illuminate/database": "^12.56|^13.0",
    "laravel/pint": "^1.0",
    "pestphp/pest": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "QuillBytes\\PayrollEngine\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "QuillBytes\\PayrollEngine\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "format:check": "vendor/bin/pint --test",
    "test": "vendor/bin/pest --configuration phpunit.xml.dist --ci",
    "release:check": "@php bin/release.php",
    "release": [
      "@php bin/release.php",
      "npm ci --no-fund --no-audit",
      "npm exec --yes -- standard-version"
    ],
    "release:first": [
      "@php bin/release.php",
      "npm ci --no-fund --no-audit",
      "npm exec --yes -- standard-version --first-release"
    ]
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "QuillBytes\\PayrollEngine\\PayrollEngineServiceProvider"
      ],
      "aliases": {
        "PayrollEngine": "QuillBytes\\PayrollEngine\\PayrollEngineFacade"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
